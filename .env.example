# Diviqra Guard — environment variables
# Copy to .env and fill in values

# API authentication
GUARD_API_KEY=guard-dev-key-local

# PostgreSQL — Diviqra shared database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/diviqra

# Redis — Diviqra shared Redis instance
REDIS_URL=redis://localhost:7379/0

# Ollama — Diviqra shared Ollama instance
OLLAMA_URL=http://localhost:11434

# Service settings
GUARD_HOST=0.0.0.0
GUARD_PORT=7008
GUARD_WORKERS=2

# Classifier model path (optional — skip if not trained yet)
CLASSIFIER_MODEL_PATH=service/models/distilbert-guard.onnx

# Logging
LOG_LEVEL=INFO

# Rate limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_TOKENS_PER_REQUEST_INGRESS=4000
MAX_TOKENS_PER_REQUEST_EGRESS=8000
